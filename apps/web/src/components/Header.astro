---
const pathname = Astro.url.pathname;
const isHome = pathname === "/";
---

<header class="sticky top-0 z-50 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between">
      <a
        href="/"
        class="text-xl font-semibold tracking-tight transition-opacity hover:opacity-70"
      >
        hkg
      </a>
      {
        !isHome && (
          <nav>
            <a
              href="/"
              class="rounded-md px-3 py-1.5 text-sm font-medium transition-colors hover:bg-neutral-800"
            >
              ← home
            </a>
          </nav>
        )
      }
    </div>
  </div>
</header>

---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Carrier Pigeon — hkg">
  <main class="mx-auto max-w-xl px-4 py-12 sm:px-6">
    <a
      href="/contact"
      class="mb-10 inline-flex items-center gap-1.5 text-sm opacity-50 hover:opacity-100 transition-opacity"
    >
      <svg
        class="h-3.5 w-3.5"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
      back
    </a>

    <div class="mt-8 mb-10">
      <p class="text-xs uppercase tracking-widest opacity-40 mb-2">you found it</p>
      <h1 class="text-3xl font-semibold tracking-tight mb-1">
        Carrier Pigeon
      </h1>
      <p class="text-lg opacity-60">respect.</p>
    </div>

    <div class="space-y-6 text-sm leading-relaxed opacity-80">
      <p class="text-base font-medium opacity-100">
        Instructions for dispatching a carrier pigeon:
      </p>

      <ol class="space-y-5">
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">1.</span>
          <div>
            <p class="font-medium opacity-100">Acquire a pigeon.</p>
            <p class="opacity-60 mt-0.5">
              Check local listings. Some cities still have them.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">2.</span>
          <div>
            <p class="font-medium opacity-100">
              Write your message on a very small piece of paper.
            </p>
            <p class="opacity-60 mt-0.5">
              Be concise. Pigeons have limited carrying capacity and, frankly,
              attention spans.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">3.</span>
          <div>
            <p class="font-medium opacity-100">
              Attach message to pigeon's leg with a small band.
            </p>
            <p class="opacity-60 mt-0.5">
              Do not use tape. Pigeons find this undignified.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">4.</span>
          <div>
            <p class="font-medium opacity-100">
              Point pigeon vaguely in my direction.
            </p>
            <p class="opacity-60 mt-0.5">
              They know where I am. They always know.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">5.</span>
          <div>
            <p class="font-medium opacity-100">Release. Say something encouraging.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-xs font-bold opacity-40 pt-0.5 w-4 shrink-0">6.</span>
          <div>
            <p class="font-medium opacity-100">Wait.</p>
            <p class="opacity-60 mt-0.5">This part may take a while.</p>
          </div>
        </li>
      </ol>
    </div>

    <div class="mt-12 border-t border-neutral-800 pt-8">
      <p class="text-sm opacity-50 mb-4">
        Alternatively, you could just use the regular contact form. It's faster,
        but less personable.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-lg border border-current px-4 py-2.5 text-sm font-medium transition-opacity hover:opacity-70"
      >
        Normal Contact Form
        <svg
          class="h-3.5 w-3.5"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </main>
</Layout>

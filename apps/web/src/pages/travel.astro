---
import Layout from "../layouts/Layout.astro";

const stats = [
  ["Clash Royale trophies", "11,536"],
  ["Intro to Geology grade", "C"],
  ["Chipotle bowls eaten", "455"],
  ["Cross country road trips", "1"],
  ["Countries traveled to", "16"],
  ["Secret Hitler games won", "52"],
  ["Poker profits", "-$590"],
  ["Unread emails", "10,400"],
  ["NDAs signed", "178"],
  ["Business cards handed out", "70"],
  ["Oscars won", "0"],
  ["Websites stolen", "1"],
];
---

<Layout title="hkg stats">
  <main class="mx-auto max-w-xl px-4 py-12 sm:px-6">
    <div class="mb-10">
      <h1 class="text-3xl font-semibold tracking-tight text-white">hkg stats</h1>
    </div>

    <ul class="divide-y divide-neutral-800">
      {stats.map(([label, value]) => (
        <li class="flex justify-between gap-4 py-3.5">
          <span class="text-sm text-neutral-400">{label}</span>
          <span class="text-sm font-medium text-white tabular-nums">{value}</span>
        </li>
      ))}
    </ul>
  </main>
</Layout>

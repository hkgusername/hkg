---
import Layout from "../layouts/Layout.astro";

const items: { text: string; underline?: boolean; suffix?: string }[] = [
  { text: "Curse of knowledge", underline: true },
  { text: "Sunk cost fallacy" },
  { text: "Familiar chaos vs unfamiliar peace" },
  { text: "Understand bubbles" },
  { text: "Belief vs Truth" },
  { text: "Maslow's Hierarchy of Needs", underline: true },
  { text: "Ask good questions" },
  { text: "Unthink consumerism" },
  { text: "Understand biases", underline: true, suffix: " (confirmation, framing, anchoring, availability, false consensus, self-serving, projection)" },
  { text: "Think critically" },
  { text: "Do takeaways" },
  { text: "Have hard conversations" },
  { text: "Be skeptical" },
  { text: "If you truly back your idea, don't drop it for anything" },
  { text: "Do things you suck at" },
  { text: "All good work starts with definitions!!!" },
  { text: "Expectation - reality = hurt" },
  { text: "Importance of pattern recognition" },
  { text: "Being able to filter good information and apply it" },
  { text: "Create more than you consume", underline: true },
  { text: "Remember what you're interested in when you're not trying to be interesting to someone else" },
  { text: "Constantly reevaluate your beliefs and frameworks", underline: true },
  { text: "S.P.I.R.E. by Tal Ben-Shahar" },
  { text: "SELF CONCEPT SELF CONCEPT SELF CONCEPT" },
  { text: "Escape stagnation" },
  { text: "Intelligence is the ability to adapt" },
  { text: "If you define stuff too early you limit what it could be" },
];
---

<Layout title="HKG's Guide — hkg">
  <main class="mx-auto max-w-xl px-4 py-12 sm:px-6">
    <div class="mb-10">
      <h1 class="text-3xl font-semibold tracking-tight text-white">HKG Guide</h1>
      <p class="mt-2 text-sm text-neutral-500">make it make sense</p>
    </div>

    <p class="mb-5 text-sm text-neutral-500 italic">Open Your Mind</p>

    <ul class="space-y-3">
      {items.map((item) => (
        <li class="flex gap-3 text-sm text-neutral-300 leading-relaxed">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-neutral-600" />
          <span>
            <span class={item.underline ? "underline underline-offset-2" : ""}>{item.text}</span>
            {item.suffix && <span>{item.suffix}</span>}
          </span>
        </li>
      ))}
    </ul>
  </main>
</Layout>

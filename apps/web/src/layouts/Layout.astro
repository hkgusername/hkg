---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
}

const { title = "hkg" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-neutral-950 text-white font-sans lowercase">
    <Header />
    <slot />
    <footer class="border-t border-neutral-800 py-8 mt-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-xs text-neutral-600">
          hkg · {new Date().getFullYear()}
        </p>
      </div>
    </footer>
  </body>
</html>

# Whitelist — ignore everything, then explicitly allow what belongs in source control

*

# --- root ---
!.gitignore
!README.md
!biome.json
!bts.jsonc
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.json

# --- apps/web ---
!apps/
!apps/web/
!apps/web/astro.config.mjs
!apps/web/package.json
!apps/web/tsconfig.json

!apps/web/public/
!apps/web/public/*

!apps/web/src/
!apps/web/src/components/
!apps/web/src/components/*
!apps/web/src/layouts/
!apps/web/src/layouts/*
!apps/web/src/pages/
!apps/web/src/pages/*
!apps/web/src/pages/product/
!apps/web/src/pages/product/*
!apps/web/src/styles/
!apps/web/src/styles/*

# --- packages ---
!packages/

!packages/config/
!packages/config/package.json
!packages/config/tsconfig.base.json

!packages/env/
!packages/env/package.json
!packages/env/tsconfig.json
!packages/env/src/
!packages/env/src/*

!packages/infra/
!packages/infra/alchemy.run.ts
!packages/infra/package.json
